# Copiar a .env y rellenar con valores reales
# NUNCA commitear el archivo .env

# Odoo 18 — solo URL y BD (las credenciales de cada usuario llegan en el JWT)
ODOO_URL=https://www.heinzsport.com
ODOO_DB=elite

# JWT — genera una clave larga y aleatoria:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=reemplaza_con_clave_de_64_caracteres_hex
JWT_EXPIRE_HOURS=8

# Servidor MCP
MCP_HOST=0.0.0.0
MCP_PORT=8001

# Audit log (ruta absoluta recomendada en producción)
AUDIT_LOG_PATH=audit.jsonl
